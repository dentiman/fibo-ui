/* Production TypeScript configuration for building and publishing to npm */
/* This extends the base tsconfig.json but overrides paths to use compiled distribution files */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@fibo-ui/cdk": [
        "./dist/fibo-ui/cdk/types/fibo-ui-cdk.d.ts"
      ],
      "@fibo-ui/components": [
        "./dist/fibo-ui/components/types/fibo-ui-components.d.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  }
}
