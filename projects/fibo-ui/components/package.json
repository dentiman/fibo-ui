{
  "name": "@fibo-ui/components",
  "version": "0.1.13",
  "description": "Signal-native Angular UI components built on @fibo-ui/cdk: fields, select, combobox, datepicker, menu, dialog, table, notifications, and more. Styled with Tailwind CSS 4",
  "keywords": [
    "angular",
    "ui",
    "components",
    "signals",
    "zoneless",
    "tailwindcss",
    "accessibility",
    "design-system"
  ],
