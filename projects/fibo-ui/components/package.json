  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dentiman/fibo-ui.git",
    "directory": "projects/fibo-ui/components"
  },
  "bugs": {
    "url": "https://github.com/dentiman/fibo-ui/issues"
  },
  "homepage": "https://github.com/dentiman/fibo-ui#readme",
  "exports": {
    "./theme": {
      "default": "./src/theme.css"
    },
    "./styles/*": {
      "default": "./src/styles/*.css"
    }
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
