    "@fibo-ui/cdk": "^0.0.11",
    "@floating-ui/dom": "^1.6.0",
    "date-fns": "^4.1.0",
    "lucide-angular": ">=0.539.0 <1.0.0",
    "rxjs": "^7.8.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "publishConfig": {
