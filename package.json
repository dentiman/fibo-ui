{
  "name": "fibo-ui",
  "version": "0.0.0",
  "description": "Signal-native Angular UI library monorepo: @fibo-ui/cdk (headless primitives), @fibo-ui/components (styled components), and a demo app",
  "author": "Denys Timanovskiy <den.timanovskiy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dentiman/fibo-ui.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:cdk": "ng build @fibo-ui/cdk",
    "build:components": "ng build @fibo-ui/components",
    "build:libs": "ng build @fibo-ui/cdk && ng build @fibo-ui/components",
    "build:libs:dev": "ng build @fibo-ui/cdk --configuration development && ng build @fibo-ui/components --configuration development",
    "watch:cdk": "ng build @fibo-ui/cdk --watch --configuration development",
    "watch:components": "ng build @fibo-ui/components --watch --configuration development",
    "build:prod": "ng build --ts-config tsconfig.prod.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@floating-ui/dom": "^1.7.3",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "date-fns": "^4.1.0",
    "lucide-angular": "^0.577.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@shikijs/langs": "^3.13.0",
    "@shikijs/markdown-it": "^3.13.0",
    "@shikijs/themes": "^3.13.0",
    "@types/jasmine": "~5.1.0",
    "@types/markdown-it": "^14.1.2",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-async": "^2.0.0",
    "ng-packagr": "^21.2.1",
    "shiki": "^3.13.0",
    "typescript": "^5.9.3"
  }
}
